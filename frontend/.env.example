# Frontend environment (Vite). Copy to `.env` for local overrides, or set these
# in the Vercel project settings for production.

# Base URL of the Prism backend API.
# - Local dev: LEAVE BLANK — calls use the relative "/api" path, which the Vite
#   dev server proxies to http://localhost:8000 (see vite.config.js).
# - Production (Vercel): set to the deployed backend, e.g.
#     VITE_API_URL=https://prism-api.up.railway.app
VITE_API_URL=
