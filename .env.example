# ---------------------------------------------------------------------------
# Prism configuration. Copy to `.env` and fill in. Every scraper degrades to
# deterministic sample data when its keys are absent (ALLOW_SAMPLE_DATA=true),
# so the full stack runs with NONE of these set.
# ---------------------------------------------------------------------------

# --- Infrastructure (docker-compose sets these; override for local runs) ---
REDIS_URL=redis://localhost:6379/0
DATABASE_URL=postgresql://prism:prism@localhost:5432/prism
RAW_STREAM=prism:raw
CONSUMER_GROUP=normalisers
DEDUP_SET_KEY=prism:seen

# --- General behaviour ------------------------------------------------------
ALLOW_SAMPLE_DATA=true
HTTP_TIMEOUT=20
USER_AGENT=PrismBot/0.1 (+https://example.com/prism)

# --- Reddit (https://www.reddit.com/prefs/apps) -----------------------------
# Reddit is OFF by default (no creds yet); the sentiment scraper skips Reddit
# and StockTwits still runs. Set true once the client id/secret below exist.
REDDIT_ENABLED=false
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=PrismBot/0.1 by u/yourname
REDDIT_SUBREDDITS=stocks,wallstreetbets,fintech

# --- StockTwits (https://api.stocktwits.com) --------------------------------
STOCKTWITS_ACCESS_TOKEN=

# --- Hiring: LinkedIn/Indeed via SerpApi Google Jobs (https://serpapi.com) ---
# One SerpApi key powers the hiring scraper. Free trial; ~$50/mo for the
# starter plan. Leave blank to use sample postings.
SERPAPI_KEY=
SERPAPI_BASE_URL=https://serpapi.com/search
HIRING_BOARDS=LinkedIn,Indeed

# --- Google Trends (pytrends; no key required) ------------------------------
TRENDS_GEO=US
TRENDS_TZ=360

# --- App reviews ------------------------------------------------------------
# Apple App Store RSS is live (no key). Google Play is STUBBED in Phase 1
# (deterministic sample reviews); no key needed yet.
PLAY_REVIEWS_API_KEY=
PLAY_REVIEWS_BASE_URL=https://serpapi.com/search

# --- SEC EDGAR (public; REQUIRES a contact email in the User-Agent) ---------
SEC_USER_AGENT=Prism your-name your-email@example.com

# --- AI synthesis & multi-model scoring (Phase 2) ---------------------------
# Claude writes the daily research briefs; GPT-4o is the secondary per-signal
# scorer. With neither key set, brief generation and model scoring are skipped
# (the rest of the pipeline runs unaffected).
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# claude-sonnet-4-6 is the current Sonnet (claude-sonnet-4-20250514 / Sonnet 4.0
# is deprecated, retires 2026-06-15). Override here without code change.
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_SCORING_MODEL=claude-sonnet-4-6
OPENAI_MODEL=gpt-4o
BRIEF_LOOKBACK_HOURS=24
# Max signals fed into each daily brief (caps prompt size on busy days).
BRIEF_MAX_SIGNALS=120
# Per-signal Claude+GPT-4o scoring (2 LLM calls each). Set false to disable.
ENABLE_MODEL_SCORING=true
MODEL_DIVERGENCE_THRESHOLD=0.3
# Where scoring runs: worker (default, the `scorer` service — off the hot path),
# inline (the normaliser scores as it ingests), or off.
SCORING_MODE=worker
SCORER_BATCH_SIZE=25
SCORER_IDLE_SECONDS=15
# Circuit breaker: pause a model after N consecutive failures for this cooldown.
SCORING_BREAKER_THRESHOLD=3
SCORING_BREAKER_COOLDOWN_SECONDS=300

# --- API security -----------------------------------------------------------
# Optional API key. When set, all data/chat endpoints require an X-API-Key
# header (the /healthz check stays open). A public SPA exposes its key, so this
# mainly gates non-browser access — rate limiting below is the real protection.
PRISM_API_KEY=
# Per-IP request limits (requests/minute; 0 disables). /chat is stricter since
# each call spends Claude credits.
RATE_LIMIT_PER_MINUTE=60
CHAT_RATE_LIMIT_PER_MINUTE=10
# Browser origins allowed to call the API (comma-separated). Local dev default
# below; in production set this to the deployed frontend URL.
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Host/port the API server binds to (uvicorn). Defaults suit local + docker;
# in production the platform's $PORT usually overrides API_PORT.
API_HOST=0.0.0.0
API_PORT=8000

# --- Email alerts (Resend, resend.com) --------------------------------------
# A scheduled digest emails new anomaly alerts. Both of the first two must be
# set or it's a no-op. ALERT_EMAIL_FROM must be a verified Resend sender;
# onboarding@resend.dev works for testing but only delivers to your own Resend
# account email. DASHBOARD_URL builds the link in the email (set to the Vercel
# URL in production).
RESEND_API_KEY=
ALERT_EMAIL_TO=
ALERT_EMAIL_FROM=Prism Alerts <onboarding@resend.dev>
DASHBOARD_URL=http://localhost:5173
# Max alerts included in a single digest email.
ALERT_DIGEST_MAX=50
