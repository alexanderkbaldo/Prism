# ---------------------------------------------------------------------------
# Prism configuration. Copy to `.env` and fill in. Every scraper degrades to
# deterministic sample data when its keys are absent (ALLOW_SAMPLE_DATA=true),
# so the full stack runs with NONE of these set.
# ---------------------------------------------------------------------------

# --- Infrastructure (docker-compose sets these; override for local runs) ---
REDIS_URL=redis://localhost:6379/0
DATABASE_URL=postgresql://prism:prism@localhost:5432/prism
RAW_STREAM=prism:raw
CONSUMER_GROUP=normalisers
DEDUP_SET_KEY=prism:seen

# --- General behaviour ------------------------------------------------------
ALLOW_SAMPLE_DATA=true
HTTP_TIMEOUT=20
USER_AGENT=PrismBot/0.1 (+https://example.com/prism)

# --- Reddit (https://www.reddit.com/prefs/apps) -----------------------------
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=PrismBot/0.1 by u/yourname
REDDIT_SUBREDDITS=stocks,wallstreetbets,fintech

# --- StockTwits (https://api.stocktwits.com) --------------------------------
STOCKTWITS_ACCESS_TOKEN=

# --- Hiring: LinkedIn/Indeed via SerpApi Google Jobs (https://serpapi.com) ---
# One SerpApi key powers the hiring scraper. Free trial; ~$50/mo for the
# starter plan. Leave blank to use sample postings.
SERPAPI_KEY=
SERPAPI_BASE_URL=https://serpapi.com/search
HIRING_BOARDS=LinkedIn,Indeed

# --- Google Trends (pytrends; no key required) ------------------------------
TRENDS_GEO=US
TRENDS_TZ=360

# --- App reviews ------------------------------------------------------------
# Apple App Store RSS is live (no key). Google Play is STUBBED in Phase 1
# (deterministic sample reviews); no key needed yet.
PLAY_REVIEWS_API_KEY=
PLAY_REVIEWS_BASE_URL=https://serpapi.com/search

# --- SEC EDGAR (public; REQUIRES a contact email in the User-Agent) ---------
SEC_USER_AGENT=Prism your-name your-email@example.com

# --- AI synthesis & multi-model scoring (Phase 2) ---------------------------
# Claude writes the daily research briefs; GPT-4o is the secondary per-signal
# scorer. With neither key set, brief generation and model scoring are skipped
# (the rest of the pipeline runs unaffected).
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# claude-sonnet-4-6 is the current Sonnet (claude-sonnet-4-20250514 / Sonnet 4.0
# is deprecated, retires 2026-06-15). Override here without code change.
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_SCORING_MODEL=claude-sonnet-4-6
OPENAI_MODEL=gpt-4o
BRIEF_LOOKBACK_HOURS=24
# Per-signal Claude+GPT-4o scoring runs inline in the normaliser (2 LLM calls
# per scored signal). Set false to disable even when keys are present.
ENABLE_MODEL_SCORING=true
MODEL_DIVERGENCE_THRESHOLD=0.3
